# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chikitsaalye
DB_USER=postgres
DB_PASSWORD=your_password_here
# Or use a full connection URL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/chikitsaalye

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret_for_access_tokens
JWT_REFRESH_SECRET=replace_with_64_byte_hex_secret_for_refresh_tokens
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── SMS (MSG91 — optional) ────────────────────────────────────
# Leave blank to use console logging in development
SMS_PROVIDER=msg91
SMS91_AUTH_KEY=your_msg91_auth_key
SMS91_SENDER_ID=CHIKIT
SMS91_TEMPLATE_ID=your_template_id

# ── File Uploads (optional) ───────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Hospital ──────────────────────────────────────────────────
DEFAULT_HOSPITAL_ID=1
